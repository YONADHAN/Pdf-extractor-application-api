
// Server configuration
PORT=3000
ENV=development
// MongoDB connection URI
MONGO_URI=mongodb://localhost:27017/pdfUploader
// JWT configuration
ACCESS_TOKEN_SECRET=your_access_token_secret_key
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=your_refresh_token_secret_key
REFRESH_TOKEN_EXPIRES_IN=7d
// Cookie configuration
COOKIE_SECRET=your_cookie_secret_key
COOKIE_EXPIRES_IN=7d
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_HTTP_ONLY=true
COOKIE_PATH_ACCESS_TOKEN=/api/auth/login
COOKIE_PATH_REFRESH_TOKEN=/api/auth/refresh-token
// Logging configuration
LOG_LEVEL=info
LOG_DIR=logs
ACCESS_LOG_DIR=logs/access
ACCESS_LOG_RETENTION_DAYS=14
ACCESS_LOG_MAX_SIZE=10m
ERROR_LOG_DIR=logs/error
ERROR_LOG_RETENTION_DAYS=30
ERROR_LOG_MAX_SIZE=10m
// CORS configuration
CORS_FRONTEND_URL=http://localhost:5173 